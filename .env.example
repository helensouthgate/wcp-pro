# ─── ENVIRONMENT VARIABLE TEMPLATE ──────────────────────────────────────────
# Copy this file to ".env" and fill in real values for local development.
# In production, set these in the Netlify dashboard instead.

# Anthropic API key for AI match predictions (https://console.anthropic.com/)
# Uses Claude Sonnet 4.6 for next-7-days predictions — billed per token.
ANTHROPIC_API_KEY=

# football-data.org API key for fixtures + live scores
# (https://www.football-data.org/client/register)
FOOTBALL_DATA_API_KEY=

# Admin password entered at /admin
ADMIN_PASSWORD=

# Long random string used to sign the admin session cookie
# Generate with: openssl rand -base64 32
ADMIN_SESSION_SECRET=
